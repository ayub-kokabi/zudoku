  it("should generate proper slugs for tags and operations", () => {
    const operations = getAllOperations({
      "/pets": {
        get: {
          tags: ["Pets & Animals"],
          responses: { "200": { description: "OK" } },
        },
        post: {
          tags: ["Pets & Animals", "Some other tag"],
          responses: { "201": { description: "Created" } },
        },
        head: {
          tags: ["Pets & Animals"],
