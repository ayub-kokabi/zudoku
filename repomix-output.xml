        </CollapsibleHeaderTrigger>
        <CollapsibleContent dir="ltr">
          <div className="grid grid-cols-[2fr_3fr] gap-x-6 text-sm">
            {sortedHeaders.slice(0, MAX_HEADERS_TO_SHOW).map(([key, value]) => (
              <Row key={key}>
                <RowContent>{key}</RowContent>
