                  {request.headers
                    .slice(MAX_HEADERS_TO_SHOW)
                    .map(([key, value]) => (
                      <Row key={key}>
                        <RowContent>{key}</RowContent>
                        <RowValue value={value} header={key} />
                      </Row>
                    ))}
                </CollapsibleContent>
                {renderHeaderToggle(
                  request.headers.length - MAX_HEADERS_TO_SHOW,
