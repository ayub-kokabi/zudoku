            type: "array",
            style: "deepObject",
            explode: true,
          },
        ],
      }),
    );
    expect(url.search).toBe("?ids%5B0%5D=a&ids%5B1%5D=b");
  });

  it("handles allowReserved", () => {
    const url = createUrl(
      "https://api.example.com",
      "/v1/products",
      makeFormData({
        queryParams: [
          {
            name: "filter",
            value: "a/b:c",
            active: true,
            allowReserved: true,
          },
        ],
      }),
    );
    expect(url.search).toBe("?filter=a/b:c");
