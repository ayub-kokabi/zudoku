    ]);
    expect(url.searchParams.get("sort")).toBe("name");
  });

  it("fills path params", () => {
    const url = createUrl(
      "https://api.example.com",
      "/v1/products/{productId}",
      makeFormData({
        pathParams: [{ name: "productId", value: "123" }],
      }),
    );
    expect(url.pathname).toBe("/v1/products/123");
  });
});
