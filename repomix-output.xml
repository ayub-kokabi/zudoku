  const name =
    typeof data === "boolean"
      ? (summary ?? "mcp-server")
      : (data?.name ?? summary ?? "mcp-server");

  const claudeConfig = `{
  "mcpServers": {
    "${name}": {
      "type": "http",
      "url": "${mcpUrl}"
    }
  }
}`;

  const cursorConfig = `{
  "mcpServers": {
    "${name}": {
      "url": "${mcpUrl}"
    }
  }
}`;

  const chatgptConfig = mcpUrl;

  const genericConfig = `{
  "mcpServers": {
    "${name}": {
      "url": "${mcpUrl}"
    }
  }
}`;

  const vscodeConfig = `{
  "servers": {
    "${name}": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "${mcpUrl}"
      ]
